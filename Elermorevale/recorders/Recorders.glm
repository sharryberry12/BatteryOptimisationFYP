object recorder {
	name Temp_recorder;
	parent ElermoreClimate;
	property temperature,solar_flux;
	interval 600;
	limit 100000;
	file output/temp.csv;
}
object recorder {
	name Tx_tap_recorder;
	parent TXZoneSubOLTC;
	property tap_A;
	interval 600;
	limit 100000;
	file output/taps.csv;
}

