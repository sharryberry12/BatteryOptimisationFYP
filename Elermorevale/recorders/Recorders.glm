// A recorder for the Zone bus
// note: the naming of the csv is important. *_recorder.csv will be excluded from the model releases. 
object recorder {
	//Zone bus meter
	name Zone_Currents_Simulated_recorder;
	parent _10053D80784J_PV;
	property measured_current_A.real, measured_current_A.imag, measured_current_B.real, measured_current_B.imag, measured_current_C.real, measured_current_C.imag, measured_voltage_A.real, measured_voltage_A.imag, measured_voltage_B.real, measured_voltage_B.imag,measured_voltage_C.real, measured_voltage_C.imag,measured_power.real,measured_power.imag, measured_power;
	interval 600;
	limit 1000000;
	file output/Zone_Simulated.csv;
}
object recorder {
	//Dist bus meter
	name DC1_recorder;
	parent HS00038585GTX00000001_LV;
	property measured_current_A.real, measured_current_A.imag, measured_current_B.real, measured_current_B.imag, measured_current_C.real, measured_current_C.imag, measured_voltage_A.real, measured_voltage_A.imag, measured_voltage_B.real, measured_voltage_B.imag,measured_voltage_C.real, measured_voltage_C.imag,measured_power_A,measured_power_B,measured_power_C;
	interval 600;
	limit 1000000;
	file output/DC1_Simulated.csv;
}
